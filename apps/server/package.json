{
  "name": "@repo/deploy-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rimraf build && npm run route:make && tsc && tsc-alias --outDir build",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx src/database/migrate.ts",
    "dev": "tsx src/index.ts",
    "lint": "npm run route:make && tsc",
    "route:make": "tsx src/router/make.ts",
    "table:integration-test": "tsx src/hooks/table-management/integration-test.ts",
    "table:self-test": "tsx src/hooks/table-management/self-test.ts"
  },
  "dependencies": {
    "@repo/configs": "workspace:*",
    "@repo/openid": "workspace:*",
    "@repo/types": "workspace:^",
    "@repo/utils-node": "workspace:^",
    "axios": "^1.15.1",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0",
    "tslib": "^2.8.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@repo/typescript-config": "workspace:^",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "tsc-alias": "1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
